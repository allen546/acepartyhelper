{
  "schemaVersion": 1,
  "id": "partyhelper",
  "version": "${version}",
  "name": "PartyHelper",
  "description": "Client-side mod to lock down teleport requests to party members only, with TOTP bypass, auto-accept, and log helpers.",
  "authors": [
    "allen"
  ],
  "contact": {
    "sources": "https://github.com/allen/partyhelper"
  },
  "license": "MIT",
  "icon": "assets/partyhelper/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.allen.partyhelper.PartyHelperMod"
    ]
  },
  "mixins": [
    "partyhelper.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "minecraft": "1.21.11",
    "fabric-api": "*"
  }
}
